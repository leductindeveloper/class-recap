<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Panel - Class Recap</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <script defer src="https://cdn.jsdelivr.net/npm/@alpinejs/[email protected]/dist/cdn.min.js"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.13.3/dist/cdn.min.js"></script>
    
    <!-- Trix Editor cho soạn thảo bài viết -->
    <link rel="stylesheet" type="text/css" href="https://unpkg.com/trix@2.0.8/dist/trix.css">
    <script type="text/javascript" src="https://unpkg.com/trix@2.0.8/dist/trix.umd.min.js"></script>

    <style>
        body { background-color: #f8fafc; font-family: 'Inter', sans-serif; }
        .sidebar-link { @apply flex items-center gap-3 px-4 py-3 rounded-xl text-gray-600 font-medium transition-all hover:bg-peachOrange hover:text-white; }
        .sidebar-link.active { @apply bg-peachOrange text-white shadow-soft; }
        trix-editor { min-height: 400px; background: white; border-radius: 0.75rem; border: 1px solid #e2e8f0; padding: 1rem; }
    </style>
</head>
<body class="text-gray-800 antialiased flex h-screen overflow-hidden">

    <!-- Sidebar -->
    <aside class="w-64 bg-white border-r border-gray-100 flex-shrink-0 flex flex-col hidden md:flex h-full shadow-sm z-20 relative">
        <div class="p-6 border-b border-gray-100">
            <a href="/" class="text-xl font-bold text-gray-900 flex items-center gap-2">
                <span class="w-8 h-8 rounded-lg bg-peachOrange flex items-center justify-center text-white text-sm">🎓</span>
                <span>Admin<span class="text-peachOrange">Panel</span></span>
            </a>
        </div>
        
        <nav class="flex-1 p-4 flex flex-col gap-2 overflow-y-auto">
            <a href="/admin" class="sidebar-link <%= typeof path !== 'undefined' && path === '/admin' ? 'active' : '' %>">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
                Dashboard
            </a>
            
            <div class="text-xs font-semibold text-gray-400 uppercase tracking-wider mt-6 mb-2 px-4">Nội Dung</div>
            <a href="/admin/recaps" class="sidebar-link <%= typeof path !== 'undefined' && path === '/admin/recaps' ? 'active' : '' %>">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path></svg>
                Bài Viết
            </a>
            <a href="/admin/gallery" class="sidebar-link <%= typeof path !== 'undefined' && path === '/admin/gallery' ? 'active' : '' %>">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                Thư Viện Ảnh
            </a>
            <a href="/admin/comments" class="sidebar-link <%= typeof path !== 'undefined' && path === '/admin/comments' ? 'active' : '' %>">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path></svg>
                Bình Luận
            </a>
            
            <div class="mt-auto pt-4 border-t border-gray-100">
                <a href="/admin/logout" class="sidebar-link text-red-500 hover:bg-red-50 hover:text-red-600">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
                    Đăng Xuất
                </a>
            </div>
        </nav>
    </aside>

    <!-- Main Content -->
    <div class="flex-1 flex flex-col h-full overflow-hidden">
        <!-- Top Header for Mobile -->
        <header class="md:hidden bg-white border-b border-gray-100 p-4 flex justify-between items-center z-10">
            <a href="/" class="text-lg font-bold text-gray-900 flex items-center gap-2">
                <span class="w-6 h-6 rounded bg-peachOrange flex items-center justify-center text-white text-xs">🎓</span>
                Admin
            </a>
            <button class="text-gray-500 focus:outline-none" onclick="document.querySelector('#mobileNav').classList.toggle('hidden')">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
            </button>
        </header>
        
        <!-- Mobile Dropdown -->
        <div id="mobileNav" class="md:hidden hidden bg-white border-b border-gray-100 p-4 absolute top-14 left-0 w-full z-20 shadow-lg">
            <a href="/admin" class="block py-2 text-gray-600 hover:text-peachOrange font-medium">Dashboard</a>
            <a href="/admin/recaps" class="block py-2 text-gray-600 hover:text-peachOrange font-medium">Bài Viết</a>
            <a href="/admin/gallery" class="block py-2 text-gray-600 hover:text-peachOrange font-medium">Thư Viện Ảnh</a>
            <a href="/admin/comments" class="block py-2 text-gray-600 hover:text-peachOrange font-medium">Bình Luận</a>
            <hr class="my-2 border-gray-100">
            <a href="/admin/logout" class="block py-2 text-red-500 font-medium">Đăng Xuất</a>
        </div>

        <!-- Scrollable Content -->
        <main class="flex-1 overflow-y-auto bg-gray-50 p-4 md:p-8">
            <%- body %>
        </main>
    </div>

</body>
</html>
