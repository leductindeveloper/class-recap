<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Admin Panel - Class Recap</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">

<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

<link rel="stylesheet" href="https://unpkg.com/trix@2.0.8/dist/trix.css">
<script src="https://unpkg.com/trix@2.0.8/dist/trix.umd.min.js"></script>

<style>

body{
background:#f8fafc;
font-family:'Inter',sans-serif;
}

/* FIX sidebar */
.sidebar-link{
display:flex;
align-items:center;
gap:12px;
padding:12px 16px;
border-radius:12px;
font-weight:500;
color:#4b5563;
transition:all .2s;
}

.sidebar-link:hover{
background:#f97316;
color:white;
}

.sidebar-link.active{
background:#f97316;
color:white;
}

trix-editor{
min-height:400px;
background:white;
border-radius:12px;
border:1px solid #e2e8f0;
padding:16px;
}

</style>
</head>

<body class="flex h-screen overflow-hidden text-gray-800">

<!-- SIDEBAR -->
<aside class="w-64 bg-white border-r flex flex-col shadow-sm">

<div class="p-6 border-b">
<a href="/" class="flex items-center gap-2 font-bold text-xl">

<span class="w-8 h-8 bg-orange-500 text-white flex items-center justify-center rounded">
🎓
</span>

Admin<span class="text-orange-500">Panel</span>

</a>
</div>

<nav class="flex-1 p-4 flex flex-col gap-2">

<a href="/admin" class="sidebar-link <%= path === '/admin' ? 'active' : '' %>">
Dashboard
</a>

<a href="/admin/recaps" class="sidebar-link <%= path === '/admin/recaps' ? 'active' : '' %>">
Bài Viết
</a>

<a href="/admin/gallery" class="sidebar-link <%= path === '/admin/gallery' ? 'active' : '' %>">
Thư Viện Ảnh
</a>

<a href="/admin/comments" class="sidebar-link <%= path === '/admin/comments' ? 'active' : '' %>">
Bình Luận
</a>

<div class="mt-auto pt-4 border-t">

<a href="/admin/logout" class="sidebar-link" style="color:#ef4444">
Đăng Xuất
</a>

</div>

</nav>
</aside>

<!-- MAIN -->
<div class="flex-1 flex flex-col overflow-hidden">

<header class="bg-white border-b p-4 font-semibold">
Admin Dashboard
</header>

<main class="flex-1 overflow-y-auto p-6 bg-gray-50">
<%- body %>
</main>

</div>

</body>
</html>
