<div class="mb-8">
    <a href="/admin/recaps" class="text-sm font-medium text-gray-500 hover:text-peachOrange flex items-center gap-1 mb-4">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        Quay lại
    </a>
    <h1 class="text-2xl font-bold text-gray-900"><%= recap ? 'Chỉnh sửa bài viết' : 'Viết Bài Mới' %></h1>
</div>

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 md:p-8">
    <form action="<%= recap ? '/admin/recaps/edit/' + recap._id : '/admin/recaps/create' %>" method="POST" enctype="multipart/form-data" class="space-y-6">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-2 space-y-6">
                <!-- Title -->
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Tiêu đề bài viết <span class="text-red-500">*</span></label>
                    <input type="text" name="title" value="<%= recap ? recap.title : '' %>" required class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-peachOrange focus:border-peachOrange transition-colors text-lg font-medium" placeholder="Ví dụ: Kỷ niệm buổi cắm trại mùa xuân...">
                </div>

                <!-- Trix Editor for Content -->
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Nội dung <span class="text-red-500">*</span></label>
                    <input id="x" type="hidden" name="content" value="<%= recap ? recap.content : '' %>">
                    <trix-editor input="x" class="prose prose-peach max-w-none text-gray-800 focus:ring-2 focus:ring-peachOrange transition-colors bg-gray-50"></trix-editor>
                </div>
            </div>

            <div class="space-y-6">
                <!-- Cover Image -->
                <div class="bg-gray-50 p-5 rounded-xl border border-gray-200" x-data="{ imageUrl: '<%= recap && recap.coverImage ? recap.coverImage : '' %>' }">
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Ảnh Bìa (Cover)</label>
                    
                    <div class="mt-1 flex justify-center px-6 pt-5 pb-6 border-2 border-gray-300 border-dashed rounded-xl relative overflow-hidden group">
                        <div class="space-y-1 text-center" x-show="!imageUrl">
                            <svg class="mx-auto h-12 w-12 text-gray-400 group-hover:text-peachOrange transition-colors" stroke="currentColor" fill="none" viewBox="0 0 48 48" aria-hidden="true"><path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                            <div class="flex text-sm text-gray-600 justify-center">
                                <label for="file-upload" class="relative cursor-pointer bg-white rounded-md font-medium text-peachOrange hover:text-orange-600 focus-within:outline-none px-1">
                                    <span>Tải ảnh lên</span>
                                    <input id="file-upload" name="coverImage" type="file" class="sr-only" accept="image/*" @change="imageUrl = URL.createObjectURL($event.target.files[0])">
                                </label>
                            </div>
                            <p class="text-xs text-gray-500">PNG, JPG, WEBP lên đến 5MB</p>
                        </div>
                        <!-- Image Preview -->
                        <img x-show="imageUrl" :src="imageUrl" class="absolute inset-0 w-full h-full object-cover">
                        <button type="button" x-show="imageUrl" @click="imageUrl = null; document.getElementById('file-upload').value = ''" class="absolute top-2 right-2 bg-white/80 p-1.5 rounded-full text-red-500 hover:bg-white transition-colors" x-cloak>
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                        </button>
                    </div>
                </div>

                <!-- Author & Tags -->
                <div class="bg-white p-5 rounded-xl border border-gray-100 shadow-sm space-y-4">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Tác giả</label>
                        <input type="text" name="author" value="<%= recap ? recap.author : 'Ban Cán Sự Lớp' %>" required class="w-full px-4 py-2 bg-gray-50 border border-gray-200 rounded-lg focus:ring-2 focus:ring-peachOrange focus:border-peachOrange transition-colors">
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Từ khóa (Tags)</label>
                        <input type="text" name="tags" value="<%= recap ? recap.tags.join(', ') : '' %>" placeholder="Ngoại khóa, Hoạt động, Dã ngoại..." class="w-full px-4 py-2 bg-gray-50 border border-gray-200 rounded-lg focus:ring-2 focus:ring-peachOrange focus:border-peachOrange transition-colors">
                        <p class="text-xs text-gray-500 mt-1">Cách nhau bằng dấu phẩy</p>
                    </div>
                </div>

                <div class="pt-4">
                    <button type="submit" class="w-full btn-primary py-3.5 text-lg flex items-center justify-center gap-2">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4"></path></svg>
                        <%= recap ? 'Cập nhật bài viết' : 'Đăng Bài Viết' %>
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>

<style>
    /* Styling for Trix editor UI inside Tailwind project */
    trix-toolbar .trix-button-group { @apply border-gray-200 rounded-md bg-white; }
    trix-toolbar .trix-button { @apply border-b-0 bg-white hover:bg-gray-50 transition-colors; }
    trix-toolbar .trix-button.trix-active { @apply bg-peachOrange/10 text-peachOrange; }
</style>

<script>
    // when editing, populate Trix editor from hidden input
    document.addEventListener('trix-initialize', function(e) {
        const hidden = document.getElementById('x');
        if (hidden && hidden.value) {
            e.target.editor.loadHTML(hidden.value);
        }
    });
</script>
