<!-- Hero Section -->
<section class="hero-bg py-24 lg:py-36 overflow-hidden relative min-h-[70vh] flex items-center">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/50 backdrop-blur-sm border border-white/20 text-sm font-medium text-peachOrange mb-8 animate-[bounce_3s_infinite]">
            <span class="relative flex h-3 w-3">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-peachOrange opacity-75"></span>
              <span class="relative inline-flex rounded-full h-3 w-3 bg-peachOrange"></span>
            </span>
            Xin chào, tụi mình là 11K! 👋
        </div>
        <h1 class="text-5xl md:text-7xl font-extrabold font-outfit tracking-tight text-gray-900 mb-6 drop-shadow-sm">
            Nơi lưu giữ thanh xuân <br class="hidden md:block" />
            <span class="gradient-text">rực rỡ nhất</span>
        </h1>
        <p class="mt-4 max-w-2xl text-lg md:text-xl text-gray-700 mx-auto mb-10 leading-relaxed font-medium">
            Tập hợp những câu chuyện buồn vui, những chuyến đi đáng nhớ và những khung hình không thể nào quên của tập thể 11K.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/recap" class="btn-primary">
                Đọc Bài Viết Mới
            </a>
            <a href="/gallery" class="px-6 py-3 bg-white text-gray-900 font-semibold rounded-xl shadow-soft hover:shadow-hover hover:-translate-y-1 transition transform duration-300 border border-gray-100">
                Xem Thư Viện Ảnh
            </a>
        </div>
    </div>
</section>

<!-- Featured (Spotlight) -->
<% if (featuredRecaps && featuredRecaps.length > 0) { %>
<section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between mb-10">
            <h2 class="text-3xl font-bold font-outfit text-gray-900 flex items-center gap-2">
                <span class="text-2xl">✨</span> Tiêu Điểm
            </h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            <% featuredRecaps.forEach(recap => { %>
                <article class="card group flex flex-col h-full cursor-pointer relative" onclick="window.location.href='/recap/<%= recap.slug %>'">
                    <div class="absolute top-4 right-4 z-10 bg-white/90 backdrop-blur px-3 py-1 rounded-full text-xs font-bold text-peachOrange shadow-sm uppercase tracking-wide">
                        Nổi bật
                    </div>
                    <div class="aspect-w-16 aspect-h-10 overflow-hidden relative">
                        <img src="<%= recap.coverImage %>" alt="<%= recap.title %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
                        <div class="absolute inset-0 bg-gradient-to-t from-gray-900/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                    </div>
                    <div class="p-6 flex flex-col flex-grow">
                        <div class="flex items-center gap-3 text-sm text-gray-500 mb-3 font-medium">
                            <span class="bg-blue-50 text-blue-600 px-2.5 py-1 rounded-md"><%= recap.tags[0] || 'Hoạt động' %></span>
                            <span><%= new Date(recap.createdAt).toLocaleDateString('vi-VN') %></span>
                        </div>
                        <h3 class="text-xl font-bold text-gray-900 mb-3 group-hover:text-peachOrange transition-colors line-clamp-2">
                            <%= recap.title %>
                        </h3>
                        <p class="text-gray-600 line-clamp-3 mb-4 flex-grow">
                            <!-- Helper truncate string or pure CSS line-clamp -->
                            <%= recap.content.replace(/<[^>]+>/g, '') %>
                        </p>
                        <div class="flex items-center justify-between mt-auto pt-4 border-t border-gray-50">
                            <div class="flex items-center gap-2 text-sm text-gray-700 font-medium">
                                <div class="w-6 h-6 rounded-full bg-pastelYellow flex items-center justify-center text-xs">👤</div>
                                <%= recap.author %>
                            </div>
                            <div class="flex gap-3 text-gray-400 text-sm">
                                <span class="flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg> <%= recap.views %></span>
                            </div>
                        </div>
                    </div>
                </article>
            <% }) %>
        </div>
    </div>
</section>
<% } %>

<!-- Latest Recap -->
<section class="py-16 lg:py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between mb-10">
            <h2 class="text-3xl font-bold font-outfit text-gray-900 flex items-center gap-2">
                <span class="text-2xl">📰</span> Mới Nhất
            </h2>
            <a href="/recap" class="text-peachOrange hover:text-orange-600 font-medium flex items-center gap-1 group">
                Xem tất cả 
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
            </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            <% if (latestRecaps && latestRecaps.length > 0) { %>
            <% latestRecaps.forEach(recap => { %>
                <article class="card group flex flex-col h-full">
                    <a href="/recap/<%= recap.slug %>" class="block aspect-w-16 aspect-h-10 overflow-hidden">
                        <img src="<%= recap.coverImage %>" alt="<%= recap.title %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                    </a>
                    <div class="p-6 flex flex-col flex-grow">
                        <div class="flex items-center gap-3 text-sm text-gray-500 mb-3">
                            <time datetime="<%= recap.createdAt %>"><%= new Date(recap.createdAt).toLocaleDateString('vi-VN') %></time>
                        </div>
                        <a href="/recap/<%= recap.slug %>" class="block mb-3">
                            <h3 class="text-xl font-bold text-gray-900 group-hover:text-peachOrange transition-colors line-clamp-2">
                                <%= recap.title %>
                            </h3>
                        </a>
                        <p class="text-gray-600 line-clamp-2 flex-grow mb-4">
                            <%= recap.content.replace(/<[^>]+>/g, '') %>
                        </p>
                        <div class="mt-auto">
                            <a href="/recap/<%= recap.slug %>" class="text-peachOrange font-semibold text-sm hover:underline inline-flex items-center gap-1">
                                Đọc tiếp <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                            </a>
                        </div>
                    </div>
                </article>
            <% }) %>
            <% } else { %>
            <div class="col-span-full text-center py-16 bg-white rounded-2xl border border-gray-100">
                <div class="text-6xl mb-4">📝</div>
                <h3 class="text-xl font-bold text-gray-800 mb-2">Chưa có bài viết nào</h3>
                <p class="text-gray-500 mb-6">Hãy đăng nhập Admin để thêm bài viết đầu tiên nhé!</p>
                <a href="/admin/login" class="btn-primary inline-block">Đăng nhập Admin</a>
            </div>
            <% } %>
        </div>
    </div>
</section>

<!-- Timeline Activity -->
<section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
            <h2 class="text-3xl font-bold font-outfit text-gray-900 mb-4 flex items-center justify-center gap-2">
                <span class="text-2xl">⏳</span> Dòng Thời Gian
            </h2>
            <p class="text-gray-600">Nhìn lại hành trình chúng ta đã đi qua.</p>
        </div>

        <div class="relative border-l-2 border-pastelYellow ml-3 md:ml-1/2 space-y-12">
            <!-- Timeline Item 1 -->
            <div class="relative pl-8 md:pl-0">
                <div class="md:w-1/2 md:pr-12 md:text-right md:ml-[-1.5px] relative">
                    <span class="absolute w-5 h-5 bg-white border-4 border-peachOrange rounded-full -left-10 md:-right-2.5 top-1"></span>
                    <time class="text-sm font-bold text-peachOrange uppercase tracking-wide">Tháng 9, 2023</time>
                    <h3 class="text-xl font-bold text-gray-900 mt-1 mb-2">Ngày tựu trường</h3>
                    <p class="text-gray-600 bg-gray-50 p-4 rounded-xl border border-gray-100 shadow-sm inline-block">Những gương mặt ngơ ngác mới quen biết nhau tại phòng học 204.</p>
                </div>
            </div>

            <!-- Timeline Item 2 -->
            <div class="relative pl-8 md:pl-0">
                <div class="md:w-1/2 md:pl-12 md:absolute md:left-1/2 md:top-0 relative">
                    <span class="absolute w-5 h-5 bg-white border-4 border-lightBlue rounded-full -left-10 md:-left-2.5 top-1"></span>
                    <time class="text-sm font-bold text-lightBlue uppercase tracking-wide">Tháng 11, 2023</time>
                    <h3 class="text-xl font-bold text-gray-900 mt-1 mb-2">Chào mừng 20/11</h3>
                    <p class="text-gray-600 bg-gray-50 p-4 rounded-xl border border-gray-100 shadow-sm inline-block">Cả lớp cùng nhau chuẩn bị tiết mục văn nghệ và cắm hoa tri ân cô chủ nhiệm.</p>
                </div>
            </div>
            
            <!-- Timeline Item 3 -->
            <div class="relative pl-8 md:pl-0 md:pt-24">
                <div class="md:w-1/2 md:pr-12 md:text-right relative">
                    <span class="absolute w-5 h-5 bg-white border-4 border-pastelYellow rounded-full -left-10 md:-right-2.5 top-1"></span>
                    <time class="text-sm font-bold text-yellow-500 uppercase tracking-wide">Tháng 3, 2024</time>
                    <h3 class="text-xl font-bold text-gray-900 mt-1 mb-2">Hội Trại Xuân</h3>
                    <p class="text-gray-600 bg-gray-50 p-4 rounded-xl border border-gray-100 shadow-sm inline-block">Lần đầu tiên cùng nhau dựng trại, đốt lửa trại ấm áp nồng nhiệt.</p>
                </div>
            </div>
        </div>
    </div>
</section>
