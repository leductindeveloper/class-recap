<header class="bg-white/80 backdrop-blur-md sticky top-0 z-50 border-b border-gray-100 shadow-sm" x-data="{ mobileMenuOpen: false, searchOpen: false, scrolled: false }" @scroll.window="scrolled = (window.pageYOffset > 20)" @keydown.escape.window="searchOpen = false">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 transition-all duration-300" :class="{ 'py-2': scrolled, 'py-4': !scrolled }">
        <div class="flex justify-between items-center">
            <!-- Logo -->
            <div class="flex-shrink-0 flex items-center">
                <a href="/" class="text-2xl font-extrabold font-outfit text-gray-900 tracking-tight flex items-center gap-2 group">
                    <span class="w-8 h-8 rounded-full bg-peachOrange flex items-center justify-center text-white text-lg shadow-soft group-hover:scale-110 transition-transform">🎓</span>
                    <span>11K<span class="text-peachOrange">Recap</span></span>
                </a>
            </div>

            <!-- Desktop Menu -->
            <nav class="hidden md:flex space-x-8">
                <a href="/" class="text-base font-medium transition-colors hover:text-peachOrange <%= typeof path !== 'undefined' && path === '/' ? 'text-peachOrange font-semibold' : 'text-gray-600' %>">Trang Chủ</a>
                <a href="/recap" class="text-base font-medium transition-colors hover:text-peachOrange <%= typeof path !== 'undefined' && path === '/recap' ? 'text-peachOrange font-semibold' : 'text-gray-600' %>">Bài Viết</a>
                <a href="/gallery" class="text-base font-medium transition-colors hover:text-peachOrange <%= typeof path !== 'undefined' && path === '/gallery' ? 'text-peachOrange font-semibold' : 'text-gray-600' %>">Thư Viện Ảnh</a>
                <a href="/about" class="text-base font-medium transition-colors hover:text-peachOrange <%= typeof path !== 'undefined' && path === '/about' ? 'text-peachOrange font-semibold' : 'text-gray-600' %>">Về Lớp Mình</a>
            </nav>

            <!-- Actions / Admin Link -->
            <div class="hidden md:flex items-center space-x-4">
                <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
                    <a href="/admin" class="text-sm font-medium text-gray-500 hover:text-gray-900 border border-gray-200 px-3 py-1.5 rounded-lg">Admin Panel</a>
                <% } %>
                <button @click="searchOpen = true" class="bg-gray-100 hover:bg-gray-200 p-2 rounded-full transition-colors" aria-label="Tìm kiếm">
                    <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                </button>
            </div>

            <!-- Mobile menu button -->
            <div class="md:hidden flex items-center">
                <button @click="mobileMenuOpen = !mobileMenuOpen" class="text-gray-600 hover:text-gray-900 focus:outline-none p-2 rounded-md">
                    <svg x-show="!mobileMenuOpen" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                    <svg x-show="mobileMenuOpen" x-cloak class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
        </div>
    </div>

    <!-- Mobile Menu -->
    <div x-show="mobileMenuOpen" x-transition.opacity x-cloak class="md:hidden bg-white border-t border-gray-100 absolute w-full shadow-lg">
        <div class="px-4 pt-2 pb-4 space-y-1">
            <a href="/" class="block px-3 py-2 rounded-md text-base font-medium text-gray-900 hover:bg-gray-50">Trang Chủ</a>
            <a href="/recap" class="block px-3 py-2 rounded-md text-base font-medium text-gray-600 hover:bg-gray-50 hover:text-gray-900">Bài Viết</a>
            <a href="/gallery" class="block px-3 py-2 rounded-md text-base font-medium text-gray-600 hover:bg-gray-50 hover:text-gray-900">Thư Viện Ảnh</a>
            <a href="/about" class="block px-3 py-2 rounded-md text-base font-medium text-gray-600 hover:bg-gray-50 hover:text-gray-900">Về Lớp Mình</a>
            <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
                <a href="/admin" class="block px-3 py-2 rounded-md text-base font-medium text-peachOrange hover:bg-orange-50 mt-4 border border-orange-100">Quản trị viên</a>
            <% } %>
            <button @click="searchOpen = true" class="block px-3 py-2 rounded-md text-base font-medium text-gray-600 hover:bg-gray-50 md:hidden">🔍 Tìm kiếm</button>
        </div>
    </div>

    <!-- Search Modal -->
    <div x-show="searchOpen" x-cloak x-transition class="fixed inset-0 z-[60] bg-gray-900/50 backdrop-blur-sm flex items-start justify-center pt-20 px-4" @click.self="searchOpen = false">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-xl p-6 relative" @click.stop>
            <button @click="searchOpen = false" class="absolute top-4 right-4 p-2 text-gray-400 hover:text-gray-600 rounded-full hover:bg-gray-100">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
            <h3 class="text-lg font-bold text-gray-900 mb-4">Tìm kiếm bài viết</h3>
            <form action="/recap" method="GET" class="flex gap-3">
                <input type="text" name="q" placeholder="Nhập từ khóa..." class="flex-1 px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-peachOrange focus:border-peachOrange" autofocus>
                <button type="submit" class="btn-primary px-6">Tìm kiếm</button>
            </form>
            <p class="text-sm text-gray-500 mt-3">Nhấn ESC để đóng</p>
        </div>
    </div>
</header>
