<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'Class Recap Website' %></title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Custom CSS (Tailwind Output) -->
    <link rel="stylesheet" href="/css/style.css">
    
    <!-- Alpine.js for lightweight interactions -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.13.3/dist/cdn.min.js"></script>
    
    <!-- Masonry for Gallery -->
    <script src="https://unpkg.com/masonry-layout@4/dist/masonry.pkgd.min.js"></script>
    <script src="https://unpkg.com/imagesloaded@5/imagesloaded.pkgd.min.js"></script>

    <style>
        /* Custom Utilities that Tailwind might miss or for special animations */
        [x-cloak] { display: none !important; }
        html { scroll-behavior: smooth; }
        .gradient-text {
            background: linear-gradient(90deg, #FFB889, #FF8E53);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .hero-bg {
            background: linear-gradient(135deg, var(--tw-colors-cream) 0%, var(--tw-colors-pastelYellow) 50%, var(--tw-colors-lightBlue) 100%);
        }
    </style>
</head>
<body class="bg-cream text-gray-800 font-sans antialiased min-h-screen flex flex-col selection:bg-peachOrange selection:text-white">

    <%- include('partials/header') %>

    <main class="flex-grow">
        <%- body %>
    </main>

    <%- include('partials/footer') %>

</body>
</html>
