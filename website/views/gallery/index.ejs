<!-- Header Gallery -->
<div class="bg-gray-50 py-16 border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl md:text-5xl font-extrabold font-outfit text-gray-900 mb-4">Thư Viện Ảnh</h1>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto mb-8">Nơi lưu giữ từng khoảnh khắc thanh xuân rực rỡ qua mỗi khung hình.</p>
        
        <!-- Filter Tabs -->
        <div class="flex flex-wrap justify-center gap-3">
            <% const galleryCats = ['Tất cả Album','Dã ngoại','Sự kiện trường','Sinh nhật lớp']; %>
            <% galleryCats.forEach(cat => { %>
                <% const clean = cat === 'Tất cả Album' ? 'Tất cả' : cat; %>
                <a href="/gallery?category=<%= encodeURIComponent(clean) %>" class="px-5 py-2.5 rounded-full font-medium text-sm transition-colors <%= (category===clean || (!category && clean==='Tất cả')) ? 'bg-peachOrange text-white' : 'bg-white text-gray-600 hover:bg-gray-50 border border-gray-200' %>"><%= cat %></a>
            <% }) %>
        </div>
    </div>
</div>

<section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <% if (albums.length === 0) { %>
            <div class="text-center py-20">
                <div class="text-6xl mb-4">📸</div>
                <h3 class="text-2xl font-bold text-gray-800 mb-2">Chưa có album nào</h3>
                <p class="text-gray-500">Ad chưa đăng tải hình ảnh nào lên, hãy quay lại sau nhé.</p>
            </div>
        <% } %>

        <div class="space-y-24">
            <% albums.forEach(album => { %>
                <div class="album-section">
                    <!-- Album Info -->
                    <div class="flex flex-col md:flex-row md:items-end justify-between mb-8 border-b border-gray-100 pb-4">
                        <div>
                            <div class="flex items-center gap-3 mb-2">
                                <span class="bg-peachOrange/10 text-orange-600 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider border border-orange-100"><%= album.category %></span>
                                <span class="text-gray-500 text-sm font-medium"><%= album.images.length %> hình ảnh</span>
                            </div>
                            <h2 class="text-3xl font-extrabold font-outfit text-gray-900"><%= album.name %></h2>
                            <% if (album.description) { %>
                                <p class="text-gray-600 mt-2 max-w-3xl"><%= album.description %></p>
                            <% } %>
                        </div>
                        <div class="mt-4 md:mt-0 pt-2 text-sm text-gray-400 font-medium">
                            Đăng ngày <%= new Date(album.createdAt).toLocaleDateString('vi-VN') %>
                        </div>
                    </div>

                    <!-- Masonry Grid -->
                    <% if (album.images.length > 0) { %>
                        <div class="masonry-grid -mx-2" x-data="{ expandedImg: null }">
                            <!-- Image Lightbox Modal (AlpineJS) -->
                            <div x-show="expandedImg" x-cloak class="fixed inset-0 z-[100] bg-gray-900/95 backdrop-blur-sm flex p-4 lg:p-12 items-center justify-center" @keydown.escape.window="expandedImg = null">
                                <button @click="expandedImg = null" class="absolute top-6 right-6 text-white/50 hover:text-white p-2 rounded-full hover:bg-white/10 transition-colors">
                                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                                </button>
                                <img :src="expandedImg" class="max-w-full max-h-full object-contain rounded-lg shadow-2xl" @click.away="expandedImg = null" x-transition.scale.origin.center>
                            </div>

                            <% album.images.forEach((img, idx) => { %>
                                <div class="masonry-item w-full sm:w-1/2 md:w-1/3 lg:w-1/4 p-2 cursor-pointer group">
                                    <div class="relative overflow-hidden rounded-2xl shadow-soft group-hover:shadow-hover transition-all duration-300 transform group-hover:-translate-y-1" @click="expandedImg = '<%= img.url %>'">
                                        <!-- Lazy loading base structure -->
                                        <img src="<%= img.url %>" alt="Gallery image <%= idx %>" class="w-full h-auto object-cover" loading="lazy">
                                        
                                        <!-- Hover Overlay -->
                                        <div class="absolute inset-0 bg-gray-900/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center backdrop-blur-[2px]">
                                            <div class="w-12 h-12 rounded-full bg-white/20 flex items-center justify-center text-white backdrop-blur-md transform scale-50 group-hover:scale-100 transition-transform duration-300">
                                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"></path></svg>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    <% } else { %>
                        <div class="bg-gray-50 border border-gray-100 rounded-2xl p-8 text-center">
                            <p class="text-gray-500 italic">Album đang trống. Hãy đợi Admin upload ảnh nhé!</p>
                        </div>
                    <% } %>
                </div>
            <% }) %>
        </div>
    </div>
</section>

<!-- Init Masonry -->
<script>
    document.addEventListener('DOMContentLoaded', function() {
        var grids = document.querySelectorAll('.masonry-grid');
        grids.forEach(function(grid) {
            imagesLoaded(grid, function() {
                var msnry = new Masonry(grid, {
                    itemSelector: '.masonry-item',
                    percentPosition: true
                });
            });
        });
    });
</script>
