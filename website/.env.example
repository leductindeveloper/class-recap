# Server
PORT=3000

# MongoDB - Dùng MongoDB Atlas (miễn phí) cho deployment
# https://www.mongodb.com/atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/class_recap?retryWrites=true&w=majority

# Session secret - Đổi thành chuỗi ngẫu nhiên bảo mật
SESSION_SECRET=your_super_secret_key_change_this

# Admin đăng nhập - NHỚ ĐỔI khi deploy production!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password
